          "rawSql": "SELECT\r\n  DATE(data_entrada) AS data,\r\n  MAX(dia_semana) AS dia_semana,\r\n  COUNT(*) AS total,\r\n  CASE \r\n    WHEN SUM(status = 'Migrado') > 0 THEN 'Tem Migrado'\r\n    ELSE 'Sem Migrado'\r\n  END AS tag_migrado\r\nFROM dados\r\nWHERE data_entrada >= STR_TO_DATE(CONCAT(${mes}, '-01'), '%Y-%m-%d')\r\n  AND data_entrada < DATE_ADD(\r\n        STR_TO_DATE(CONCAT(${mes}, '-01'), '%Y-%m-%d'),\r\n        INTERVAL 1 MONTH\r\n      )\r\nGROUP BY DATE(data_entrada)\r\nORDER BY data;",
